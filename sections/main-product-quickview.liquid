<div class="product-quickview">
  {% liquid
    assign product_url = shop.url | append: product.url
  %}

  <product-section class="block">
    <div class="product md:grid md:grid-cols-[minmax(0,1fr)_365px] md:gap-40">

      <div class="relative">
        <div class="block md:grid md:grid-cols-[minmax(0,50px)_minmax(0,1fr)] md:gap-10">
          <div class="relative hidden md:block">
            <ul class="product-thumbs swiper w-full inset md:overflow-hidden" style="position:absolute" role="list">
              <div class="swiper-wrapper">
                {% for media in product.media %}
                  <li class="swiper-slide group/thumb cursor-pointer" style="height:auto; aspect-ratio: 3 / 4;" data-media-id="thumbs-{{ section.id }}-{{ media.id }}">
                    <div class="aspect-product overflow-hidden relative border-1 border-transparent transition-colors group-[.swiper-slide-thumb-active]/thumb:border-black">
                      {% render 'image'
                        image: media,
                        classes: 'size-full inset object-cover',
                        sizes: '300x',
                        include_placeholder: true,
                        placeholder_name: 'product-1',
                        src_set_type: 'thumbnail'
                      %}
                    </div>
                  </li>
                {% endfor %}
              </div>
            </ul>
          </div>
          <ul class="product-slider swiper w-full md:overflow-hidden" role="list">
            <div class="swiper-wrapper">
              {% for media in product.media %}
                {% if media.media_type == "image" %}
                  {% assign image_variants = product.images | where: 'src', media.src | first %}
                {% endif %}
                <li data-initial-slide="{% if product.selected_or_first_available_variant.image == media %}true{% else %}false{% endif %}" data-media-index="{{ forloop.index0 }}" class="swiper-slide" data-media-id="{{ section.id }}-{{ media.id }}" {% if media.media_type == "image" %}data-image-variants="{{ image_variants.variants | map: 'id' | join: "," }}"{% endif %}>
                  <div class="aspect-product overflow-hidden relative">
                    {% render 'image'
                      image: media,
                      classes: 'size-full inset object-cover',
                      sizes: '(min-width: 769px) 60vw, 100vw',
                      include_placeholder: true,
                      placeholder_name: 'product-1',
                      src_set_type: 'full-width'
                    %}
                  </div>
                </li>
              {% endfor %}
            </div>
            <div class="absolute z-20 bottom-20 left-half -translate-x-half md:hidden">
              <div class="swiper-pagination"></div>
            </div>
          </ul>

        </div>
        <div class="absolute z-20 md:hidden{% if slider_mobile_style == 'center' %} top-10 left-0{% else %} top-13 left-13{% endif %}">
          {% render 'product-badges' prod: product %}
        </div>
        <div class="p-5 absolute left-auto right-0 top-0 z-[1]"> 
          <!-- Swym Wishlist Plus EPI Button with default first variant -->   
            <div class="swym-button-bar swym-wishlist-button-bar">
              <div class="swym-btn-container" data-position="default">
                <button aria-label="Add to Wishlist" id="swym-quick-view" data-with-epi="true" class="swym-button swym-add-to-wishlist product_{{product.id}}" data-swaction="addToWishlist" data-product-id="{{product.id | json}}" data-variant-id="{{ product.variants[0].id }}" data-product-url="{{ shop.url }}{{ product.url }}">
                  <svg width="19" height="16" viewBox="0 0 19 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M13.6836 0.505859C14.8998 0.442806 15.9126 0.921544 16.6074 1.74512C17.9567 3.3446 18.1849 6.39599 15.9023 9.46582L15.6738 9.7627C13.9681 11.9037 11.4113 13.871 9.06152 15.4941C6.71112 13.8699 4.15679 11.905 2.4502 9.7627C-0.0748214 6.59426 0.122995 3.39527 1.51562 1.74414C2.21034 0.920664 3.22338 0.442782 4.43945 0.505859C5.66479 0.56942 7.14336 1.18681 8.7207 2.65527L9.06152 2.97266L9.40234 2.65527C10.9796 1.18702 12.4582 0.569436 13.6836 0.505859Z" stroke="#472715"></path>
                  </svg>
                  <svg width="19" height="16" viewBox="0 0 19 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <g clip-path="url(#clip0_1621_7)">
                    <path d="M13.6839 0.5058C14.9001 0.442747 15.9129 0.921485 16.6077 1.74506C17.957 3.34454 18.1852 6.39593 15.9026 9.46576L15.6741 9.76264C13.9684 11.9036 11.4116 13.8709 9.06186 15.494C6.71146 13.8698 4.15713 11.9049 2.45054 9.76264C-0.0744842 6.5942 0.123332 3.39521 1.51596 1.74408C2.21068 0.920605 3.22372 0.442723 4.43979 0.5058C5.66513 0.569361 7.1437 1.18675 8.72104 2.65521L9.06186 2.9726L9.40268 2.65521C10.9799 1.18696 12.4585 0.569377 13.6839 0.5058Z" fill="#472715" stroke="#472715"></path>
                    </g>
                    <defs>
                    <clipPath id="clip0_1621_7">
                    <rect width="19" height="16" fill="white"></rect>
                    </clipPath>
                    </defs>
                  </svg>
                </button> 
              </div>
            </div>    
          <!-- Swym Wishlist Plus EPI Button-->
        </div>
      </div>

      <div id="ProductInfo-{{ section.id }}" class="pt-20">
        {% assign product_form_id = 'product-form-' | append: section.id %}

        <div class="sticky-bar w-full">
          {% render 'product-badges' prod: product, classes: 'mb-20 hidden md:block' %}

          <div class="{% if mobile_title_position == 'above' %} hidden md:block{% endif %}">
            <h1 class="mb-10 text-m-h2 font-serif md:text-h3">
              {{ product.title | escape }}
            </h1>

            <p class="price mb-20 flex items-center gap-5 text-body-2">
              {{ product.price | money }}
              {% if product.compare_at_price > product.price %}
                <span class="line-through opacity-50">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </p>
          </div>

          {% if product.description != blank %}
            <div class="rte mb-30 text-body-4 hidden md:block">
              {{ product.description }}
            </div>
          {% endif %}

          {% render 'product-form' prod: product, product_form_id: product_form_id, show_quantity: false, change_url: false %}

          {% if section.settings.extra_text != blank %}
            <p class="mt-10 text-caption font-serif text-center">{{ section.settings.extra_text }}</p>
          {% endif %}

          <div class="mt-10 text-center">
            <a href="{{ product.url | within: collection }}" class="text-body-4 underline">View Full Product Details</a>
          </div>
        </div>
      </div>
    </div>
  </product-section>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    function isIE() {
      const ua = window.navigator.userAgent;
      const msie = ua.indexOf('MSIE ');
      const trident = ua.indexOf('Trident/');

      return (msie > 0 || trident > 0);
    }

    if (!isIE()) return;
    const hiddenInput = document.querySelector('#{{ product_form_id }} input[name="id"]');
    const noScriptInputWrapper = document.createElement('div');
    const variantSwitcher = document.querySelector('variant-radios[data-section="{{ section.id }}"]') || document.querySelector('variant-selects[data-section="{{ section.id }}"]');
    noScriptInputWrapper.innerHTML = document.querySelector('.product-form__noscript-wrapper-{{ section.id }}').textContent;
    variantSwitcher.outerHTML = noScriptInputWrapper.outerHTML;

    document.querySelector('#Variants-{{ section.id }}').addEventListener('change', function(event) {
      hiddenInput.value = event.currentTarget.value;
    });
  });
</script>

{% liquid
  if product.selected_or_first_available_variant.featured_media
    assign seo_media = product.selected_or_first_available_variant.featured_media
  else
    assign seo_media = product.featured_media
  endif
%}

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

{% schema %}
  {
    "name": "Product - Quickview",
    "settings": [
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "extra_text",
        "label": "Extra Text"
      }
    ]
  }
{% endschema %}
