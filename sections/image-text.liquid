{% assign bg_color = section.settings.background_color %}

<div class="
    flex flex-col gap-30 md:gap-20 {{ section.settings.content_color }}
    {% if section.settings.add_margin %} my-60 md:my-80{% endif %}
    {% if section.settings.image_position == 'left' %} md:flex-row{% else %} md:flex-row-reverse{% endif %}
  "
  {% if bg_color != blank and bg_color != 'rgba(0,0,0,0)' %} style="background-color: {{ bg_color }}"{% endif %}
>
  <div class="pb-full relative overflow-hidden md:w-1/2 md:pb-half">
    {% if section.settings.media_type == 'image' %}
      {% render 'image'
        image: section.settings.image,
        classes: 'size-full inset object-cover',
        sizes: '100vw',
        include_placeholder: true,
        placeholder_name: 'lifestyle-2',
        src_set_type: 'full-width'
      %}
    {% else %}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'size-full object-cover', image_size: '1000x' }}
    {% endif %}
  </div>
  <div class="mx-60 flex justify-center items-center text-center md:w-1/2 md:mx-0 md:my-40{% if bg_color != blank and bg_color != 'rgba(0,0,0,0)' %} pt-10 pb-50 md:p-0{% endif %}">
    <div class="max-w-custom w-full flex flex-col gap-10 md:gap-20" style="--width: {{ section.settings.content_width }}px;">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Image / Text",
    "settings": [
      {
        "type": "header",
        "content": "Config"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color"
      },
      {
        "type": "select",
        "id": "content_color",
        "options": [
          { "value": "text-white", "label": "Light" },
          { "value": "text-text", "label": "Dark" }
        ],
        "default": "text-text",
        "label": "Content Color"
      },
      {
        "type": "select",
        "id": "image_position",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "right", "label": "Right" }
        ],
        "default": "left",
        "label": "Image Position"
      },
      {
        "type": "number",
        "id": "content_width",
        "label": "Content Width",
        "default": 380
      },
      {
        "type": "checkbox",
        "id": "add_margin",
        "label": "Add Margin",
        "default": true
      },
      {
        "type": "header",
        "content": "Media"
      },
      {
        "type": "select",
        "id": "media_type",
        "options": [
          { "value": "image", "label": "Image" },
          { "value": "video", "label": "Video" }
        ],
        "default": "image",
        "label": "Media Type"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image",
        "visible_if": "{{ section.settings.media_type == 'image' }}"
      },
      {
        "type": "image_picker",
        "id": "mobile_image",
        "label": "Mobile Image",
        "visible_if": "{{ section.settings.media_type == 'image' }}"
      },
      {
        "type": "video",
        "id": "video",
        "label": "Video",
        "visible_if": "{{ section.settings.media_type == 'video' }}"
      }
    ],
    "blocks": [{ "type": "@theme" }],
    "presets": [
      {
        "name": "Image / Text",
        "category": "Storytelling",
        "blocks": [
          {
            "type": "subtitle"
          },
          {
            "type": "title"
          },
          {
            "type": "text"
          },
          {
            "type": "button"
          }
        ]
      }
    ]
  }
{% endschema %}