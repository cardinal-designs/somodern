{% liquid
  assign paginate_by = 36
  assign total_active_values = 0
  
  for filter in collection.filters
    assign total_active_values = total_active_values | plus: filter.active_values.size
  endfor

  if collection.url
    assign results_url = collection.url
  else 
    assign terms = collection.terms | escape
    assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
  endif

  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign sort_by_text = 'Featured'
  case sort_by
    when 'best-selling'
      assign sort_by_text = 'Best Sellers'
    when 'price-ascending'
      assign sort_by_text = 'Price: Low to High'
    when 'price-descending'
      assign sort_by_text = 'Price: High to Low'
  endcase
%}

{% render 'breadcrumbs' show_home: true %}

<div class="page-width overflow-hidden md:overflow-visible">
  {% if collection.image != blank %}
    <header class="flex flex-col-reverse md:mb-30 md:grid md:grid-cols-[430px_1fr] md:items-center lg:gap-40">
      <div class="py-30 md:py-40">
        <h1 class="text-m-h2 font-serif md:text-h3" data-animate>{{ collection.title }}</h1>
        {% if collection.description != blank %}
          <div class="max-w-custom w-full mt-10 text-m-body-2 md:mt-20 md:text-body-2" style="--width: 295px;" data-animate>{{ collection.description }}</div>
        {% endif %}
      </div>
      <div class="h-0 -mx-20 pb-[55%] relative md:min-h-[360px] md:p-0 md:translate-x-50">
        {% render 'image'
          image: collection.image,
          classes: 'size-full inset object-cover',
          sizes: '(min-width: 767px) 75vw, 100vw',
          src_set_type: 'full-width'
        %}
      </div>
    </header>
  {% else %}
    <header class="max-w-custom my-30 md:mt-60 md:mb-40" style="--width: 630px;">
      <h1 class="text-m-h2 font-serif md:text-h3" data-animate>{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="mt-20 text-m-body-2 md:mt-20 md:text-body-2" data-animate>{{ collection.description }}</div>
      {% endif %}
    </header>
  {% endif %}

  <collection-filters class="collection-filters mb-20 block relative" data-base-url="{{ collection.url }}" data-collection-url="{{ collection.url }}" data-current-sort="{{ collection.sort_by | default: collection.default_sort_by }}">
    <div class="md:grid md:grid-cols-[0.25fr_0.75fr] md:gap-20">
      {% render 'filters' %}

      <div class="">
        <div class="mb-20 -mx-20 px-20 pb-10 flex justify-between items-center gap-20 border-b-1 border-tan md:mx-0 md:p-0 md:border-0">
          <p id="product-count-2" class="text-m-sh2 uppercase hidden md:block md:text-sh2">{{ collection.products_count }} Product{% unless collection.products_count == 1 %}s{% endunless %}</p>
          <button class="flex items-center gap-13 text-body-3 md:hidden" data-open-filters>
            {% render 'icon' icon: 'filter' %}
            Filter
          </button>
          <form class="sort-form flex-shrink-0 relative">
            <dropdown-item data-is-overlay="true">
              <div class="group/dropdown flex justify-end relative" data-dropdown>
                <button class="dropdown-header-sort py-10 flex justify-between items-center gap-10 text-body-3" data-dropdown-toggle>
                  <span>
                    <span class="hidden md:inline-block">Sort By:&nbsp;</span><span class="sort-by-current">{{ sort_by_text }}</span>
                  </span>
                  <span class="transition-transform ease-in-out group-[.active]/dropdown:rotate-180">
                    {% render 'icon' icon: 'dropdown-large' %}
                  </span>
                </button>
                <div class="min-w-[150px] absolute top-full right-0 translate-y-10 bg-background z-30 shadow-dropdown text-right hidden group-[.active]/dropdown:block md:translate-y-20" data-dropdown-content>
                  <div class="py-10 px-20 flex flex-col gap-5">
                    <div>
                      <input type="radio"
                        class="sort-button peer visually-hidden"
                        name="sort_by"
                        value="best-selling"
                        id="Sort-1"
                        data-display="Best Sellers"
                        {% if 'best-selling' == sort_by %}checked{% endif %}
                      >
                      <label for="Sort-1" class="text-body-3 opacity-50 transition-colors cursor-pointer peer-checked:opacity-100">
                        Best Sellers
                      </label>
                    </div>
                    <div>
                      <input type="radio"
                        class="sort-button peer visually-hidden"
                        name="sort_by"
                        value="manual"
                        id="Sort-2"
                        data-display="Featured"
                        {% if 'manual' == sort_by %}checked{% endif %}
                      >
                      <label for="Sort-2" class="text-body-3 opacity-50 transition-colors cursor-pointer peer-checked:opacity-100">
                        Featured
                      </label>
                    </div>
                    <div>
                      <input type="radio"
                        class="sort-button peer visually-hidden"
                        name="sort_by"
                        value="price-ascending"
                        id="Sort-3"
                        data-display="Price: Low to High"
                        {% if 'price-ascending' == sort_by %}checked{% endif %}
                      >
                      <label for="Sort-3" class="text-body-3 opacity-50 transition-colors cursor-pointer peer-checked:opacity-100">
                        Price: Low to High
                      </label>
                    </div>
                    <div>
                      <input type="radio"
                        class="sort-button peer visually-hidden"
                        name="sort_by"
                        value="price-descending"
                        id="Sort-4"
                        data-display="Price: High to Low"
                        {% if 'price-descending' == sort_by %}checked{% endif %}
                      >
                      <label for="Sort-4" class="text-body-3 opacity-50 transition-colors cursor-pointer peer-checked:opacity-100">
                        Price: High to Low
                      </label>
                    </div>

                  </div>
                </div>
              </div>
            </dropdown-item>
          </form>
        </div>
        <div id="active-filters">
        {% if total_active_values > 0 %}
          <div class="my-20 flex gap-x-20 gap-y-10 flex-wrap md:p-0">
            {% for filter in collection.filters %}
              {% case filter.type %}
                {% when 'list' %}
                  {% for value in filter.active_values %}
                    <button class="px-[8px] py-[3px] flex flex-wrap items-center gap-10 text-body-2 bg-taupe text-white" data-remove-filter data-url="{{ filter.url_to_remove | remove: '%2F%3Fsection_id%3Dproduct-grid' }}" data-filter="{{ value.param_name }}-{{ value.value }}">
                      {{ value.label | escape }}
                      <div class="[&_svg]:w-[10px] [&_svg]:h-auto">
                        {% render 'icon' icon: 'close' %}
                      </div>
                    </button>
                  {% endfor %}
                {% when 'price_range' %}
                  {% if filter.min_value or filter.max_value %}
                    {% assign min_value = filter.min_value.value | default: 0 %}
                    {% assign max_value = filter.max_value.value | default: filter.range_max %}
                    {% assign min_value_formatted = min_value | money_without_trailing_zeros %}
                    {% assign max_value_formatted = max_value | money_without_trailing_zeros %}
                    
                    {% if min_value != 0 or max_value != filter.range_max %}
                      <button class="price-range px-[8px] py-[3px] flex flex-wrap items-center gap-10 text-body-2 bg-taupe text-white" data-remove-filter data-url="{{ filter.url_to_remove | remove: '%2F%3Fsection_id%3Dproduct-grid' }}" data-filter="{{ value.param_name }}-{{ value.value }}">
                        {{ min_value_formatted }} - {{ max_value_formatted }}
                        <div class="[&_svg]:w-[10px] [&_svg]:h-auto">
                          {% render 'icon' icon: 'close' %}
                        </div>
                      </button>
                    {% endif %}
                  {% endif %}
              {% endcase %}
            {% endfor %}
            <button class="text-body-3 opacity-50 underline" data-clear-all-filters>Clear Filters</button>
          </div>
        {% endif %}
      </div>
        <div id="product-grid" class="mb-50 mb:mb-80">
          {% paginate collection.products by paginate_by %}
            {% if collection.products.size == 0 %}
              <div class="page-width mt-60 mb-150" data-id="{{ section.id }}">
                <div class="loading-overlay"></div>
                <div class="text-center">
                  <p class="mb-20 text-body-1">No products found.</p>
                  <a href="{{ collection.url }}" class="button">Clear Filters</a>
                </div>
              </div>
            {% else %}
              <div class="collection">
                <div class="loading-overlay"></div>

                <ul
                  class="
                    product-grid-container group/product-grid grid grid-cols-2 gap-x-20 gap-y-40 grid-flow-row-dense
                    md:grid-cols-3 md:gap-y-60
                  "
                  data-id="{{ section.id }}"
                  data-desktop="4"
                  data-mobile="2"
                >
                  {% for product in collection.products %}
                    {% liquid
                      assign current_page0 = paginate.current_page | minus: 1
                      assign page_start = paginate_by | times: current_page0
                      assign product_index = forloop.index | plus: page_start

                      assign prioritize_loading = false
                      if forloop.index < 5
                        assign prioritize_loading = true
                      endif
                    %}

                    {% if total_active_values == 0 %}
                      {% for block in section.blocks %}
                        {% assign card_position = block.settings.card_position | abs %}
                        {% if product_index == card_position and total_active_values == 0 %}
                          <li class="product-grid-item col-span-full{% if block.settings.card_size == 'large' %} md:col-span-2{% else %} md:col-span-1{% endif %}" data-animate>
                            {% render 'collection-card' block: block, prioritize_loading: prioritize_loading %}
                          </li>
                        {% endif %}
                      {% endfor %}
                    {% endif %}

                    <li class="product-grid-item" data-animate>
                      {% render 'product-card' prod: product, prioritize_loading: prioritize_loading %}
                    </li> 
                  {% endfor %}
                </ul>

                {% render 'pagination', paginate: paginate, anchor: '', show_item_count: true, load_more: section.settings.pagination, target: '#product-grid' %}
              </div>
            {% endif %}
          {% endpaginate %}
        </div>
        {% if collection.metafields.custom.description != blank %}
          <div class="max-w-[660px] w-full mx-auto mb-60 text-body-4 text-center opacity-50 md:mb-70" data-animate>{{ collection.metafields.custom.description | metafield_tag }}</div>
        {% endif %}
      </div>
    </div>
  </collection-filters>
</div>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "select",
      "id": "pagination",
      "label": "Pagination style",
      "options": [
        {"label": "Load More", "value": "true"},
        {"label": "Page numbers", "value": "false"}
      ],
      "default": "false"
    }
  ],
  "blocks": [
    {
      "type": "promo_card",
      "name": "Promo Card",
      "settings": [
        {
          "type": "header",
          "content": "Config" 
        },
        {
          "type": "number",
          "id": "card_position",
          "label": "Card Position",
          "default": 1,
          "info": "Enter in a number." 
        },
        {
          "type": "select",
          "id": "card_size",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "large", "label": "Large" }
          ],
          "default": "small",
          "label": "Card Size"
        },
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "checkbox",
          "id": "add_overlay",
          "label": "Add Overlay"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "button_style",
          "options": [
            { "value": "button", "label": "Button" },
            { "value": "text", "label": "Text" }
          ],
          "default": "text",
          "label": "Button Style"
        }
      ]
    }
  ]
}
{% endschema %}
