<div class="page-width max-w-custom w-full mx-auto my-60 md:my-80" style="--width: 1440px;">
  <div class="">
    <div class="h-[236px] w-[177px] mx-auto relative overflow-hidden md:h-[276px] md:w-[207px] md:ml-auto md:mr-[8%]" data-animate>
      {% render 'image'
        image: section.settings.image_1,
        classes: 'size-full inset object-cover',
        include_placeholder: true,
        placeholder_name: 'collection-1',
        sizes: '400px',
        src_set_type: 'grid'
      %}
    </div>
  </div>
  <div class="flex flex-col-reverse items-center md:-mt-30 md:grid grid-cols-thirds md:gap-80">
    <div class="max-w-custom w-full mx-auto md:max-w-full" style="--width: 276px;" data-animate>
      {% render 'image'
        image: section.settings.image_2,
        classes: 'aspect-tall overflow-hidden object-cover md:max-w-[230px] xl:max-w-[320px]',
        include_placeholder: true,
        placeholder_name: 'collection-1',
        sizes: '500px',
        src_set_type: 'grid'
      %}
    </div>
    <div class="">
      <div class="max-w-custom w-full mx-auto text-center my-60 md:m-0" style="--width: 475px;">
        <div class="text-m-h1 font-serif md:text-h2" data-animate>{{ section.settings.title }}</div>
        {% if section.settings.text != blank %}
          <div class="rte max-w-custom w-full mt-20 mx-auto text-m-body-2 md:text-body-3" style="--width: 405px;" data-animate>{{ section.settings.text }}</div>
        {% endif %}
        {% if section.settings.button_label != blank %}
          {% if section.settings.button_style == 'button' %}
            <a href="{{ section.settings.button_link }}" class="button mt-30" data-animate>{{ section.settings.button_label }}</a>
          {% else %}
            <div class="mt-30" data-animate>
              {% render 'text-link' link: section.settings.button_link, label: section.settings.button_label %}
            </div>
          {% endif %}
        {% endif %}
      </div>
    </div>
    <div class="">

    </div>
  </div>
  <div class="mt-60 xl:-mt-30" data-animate>
    {% render 'image'
        image: section.settings.image_3,
        classes: 'ml-auto aspect-wide overflow-hidden object-cover md:w-[40%] xl:w-[50%]',
        include_placeholder: true,
        placeholder_name: 'collection-1',
        sizes: '800px',
        src_set_type: 'grid'
      %}
  </div>
</div>

{% schema %}
  {
    "name": "Collage",
    "settings": [
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Lorem Ipsum Dolor"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Text",
        "default": "<p>Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia.</p>"
      },
      {
        "type": "header",
        "content": "Button"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button Label"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      },
      {
        "type": "select",
        "id": "button_style",
        "options": [
          { "value": "button", "label": "Button" },
          { "value": "text", "label": "Text" }
        ],
        "default": "button",
        "label": "Button Style"
      },
      {
        "type": "header",
        "content": "Images"
      },
      {
        "type": "image_picker",
        "id": "image_1",
        "label": "Image 1"
      },
      {
        "type": "image_picker",
        "id": "image_2",
        "label": "Image 2"
      },
      {
        "type": "image_picker",
        "id": "image_3",
        "label": "Image 3"
      }
    ],
    "presets": [
      {
        "name": "Collage",
        "category": "Storytelling"
      }
    ]
  }
{% endschema %}