<div class="min-h-[100vh] py-80 px-20 flex justify-center items-center relative md:py-100 md:items-start" style="background-color: {{ section.settings.background_color }};">
  {% liquid
    assign desktop_classes = 'size-full inset object-cover'
    if section.settings.mobile_image != blank
      assign desktop_classes = 'size-full inset object-cover hidden md:block'
    endif
  %}

  {% if section.settings.background_image != blank %}
    {% render 'image'
      image: section.settings.background_image,
      classes: desktop_classes,
      sizes: '100vw',
      include_placeholder: true,
      placeholder_name: 'lifestyle-2',
      src_set_type: 'full-width',
      prioritize_loading: true
    %}

    {% if section.settings.mobile_image != blank %}
      {% render 'image'
        image: section.settings.mobile_image,
        classes: 'size-full inset object-cover md:hidden',
        sizes: '100vw',
        include_placeholder: true,
        placeholder_name: 'lifestyle-2',
        src_set_type: 'full-width',
        prioritize_loading: true
      %}
    {% endif %}
  {% endif %}

  <div class="max-w-custom w-full mx-auto pb-80 relative" style="--width: 515px;">
    <div class="logo mb-70 mx-auto text-center md:w-auto md:h-auto">
      {% if section.settings.logo != blank %}
        <a href="{{ routes.root_url }}" class="block relative" aria-label="Header Logo Link">
          {% if enable_transparent_header and section.settings.transparent_logo != blank %}
            {{ section.settings.transparent_logo | image_url: width: 250 | image_tag: width: section.settings.transparent_logo.width, class: 'header-logo-transparent absolute top-0 transition-opacity group-hover/header:opacity-0 group-[.scrolled]/html:opacity-0', sizes: '250px', widths: '100, 150, 200, 300' }}
            {{ section.settings.logo | image_url: width: 250 | image_tag: width: section.settings.logo.width, class: 'header-logo w-full opacity-0 transition-opacity group-hover/header:opacity-100 group-[.scrolled]/html:opacity-100', sizes: '250px', widths: '100, 150, 200, 300' }}
          {% else %}
            {{ section.settings.logo | image_url: width: 250 | image_tag: width: section.settings.logo.width, class: 'header-logo w-full', sizes: '250px', widths: '100, 150, 200, 300' }}
          {% endif %}
        </a>
      {% else %}
        <a href="{{ routes.root_url }}" class="py-10 text-m-h2 font-serif italic md:p-0 md:text-h2">{{ shop.name }}</a>
      {% endif %}
    </div>

    <div class="px-20 py-30 md:p-40{% if section.settings.content_color == 'light' %} text-white{% endif %}"{% if section.settings.content_background_color != blank %} style="background-color: {{ section.settings.content_background_color }};"{% endif %}>
      <div class="max-w-custom w-full mx-auto text-center" style="--width: 400px;">
        <h1 class="visually-hidden">{{ shop.name }}</h1>
        <h2 class="mb-20 text-m-h1 font-serif italic md:text-h1">{{ section.settings.title }}</h2>
        <p class="text-m-body-2 md:text-body-2">{{ section.settings.text | newline_to_br }}</p>
      </div>

      {% form 'customer', class: 'newsletter-form mt-30' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="flex">
          <div class="field w-full">
            <label class="field__label mb-10 text-sh2 uppercase" for="NewsletterForm--{{ section.id }}">Email</label>
            <input
              id="NewsletterForm--{{ section.id }}"
              type="email"
              name="contact[email]"
              class="field__input{% if section.settings.content_color == 'light' %} border-white text-white placeholder:text-white/50{% endif %}"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
                aria-describedby="Newsletter-error--{{ section.id }}"
              {% elsif form.posted_successfully? %}
                aria-describedby="Newsletter-success--{{ section.id }}"
              {% endif %}
              placeholder="Email"
              required
            >
          </div>
        </div>
        <button type="submit" class="button w-full mt-20{% if section.settings.content_color == 'light' %} button--white{% endif %}" name="commit" id="Subscribe" aria-label="{{ 'newsletter.button_label' | t }}">Sign Up For Details</button>
        {% if form.errors %}
          <p class="mt-15 text-body-2 text-error" id="Newsletter-error--{{ section.id }}">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
        {% endif %}
        {% if form.posted_successfully? %}
          <p class="mt-15 text-body-2" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>{{ 'newsletter.success' | t }}</p>
        {% endif %}
      {% endform %}

      <div class="mt-30 mx-auto flex justify-center [&_svg]:w-[16px]">{% render 'social' %}</div>
    </div>
  </div>
</div>

<style>
  .logo {
    width: {{ section.settings.logo_width }}px;
  }

  @media screen and (max-width: 767px) {
    .logo {
      width: {{ section.settings.mobile_logo_width }}px;
    }
  }
</style>

{% schema %}
  {
    "name": "Landing",
    "settings": [
      {
        "type": "header",
        "content": "Logo"
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 200,
        "step": 5,
        "unit": "px",
        "label": "Logo Width",
        "default": 145
      },
      {
        "type": "range",
        "id": "mobile_logo_width",
        "min": 50,
        "max": 200,
        "step": 5,
        "unit": "px",
        "label": "Mobile Logo Width",
        "default": 110
      },
      {
        "type": "header",
        "content": "Media"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color"
      },
      {
        "type": "image_picker",
        "id": "background_image",
        "label": "Background Image"
      },
      {
        "type": "image_picker",
        "id": "mobile_background_image",
        "label": "Mobile Background Image"
      },
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "color",
        "id": "content_background_color",
        "label": "Content Background Color",
        "default": "#FFFFFF"
      },
      {
        "type": "select",
        "id": "content_color",
        "options": [
          { "value": "light", "label": "Light" },
          { "value": "dark", "label": "Dark" }
        ],
        "default": "dark",
        "label": "Content Color"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Coming Soon!"
      },
      {
        "type": "inline_richtext",
        "id": "text",
        "label": "Text",
        "default": "Subscribe to be notified of launch dates, future product features and more!"
      }
    ]
  }
{% endschema %}