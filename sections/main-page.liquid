<div class="page-width my-60 md:mb-100">
  <div class="max-w-custom w-full mx-auto mb-40 text-center md:mb-60" style="--width: 630px;">
    <h1 class="text-m-h1 font-serif italic md:text-h1">{{ page.title }}</h1>
    {% if section.settings.additional_text != blank %}
      <p class="mt-10 text-m-body-2 opacity-50 md:mt-20 md:text-body-2">{{ section.settings.additional_text }}</p>
    {% endif %}
  </div>
  <div class="text-editor max-w-custom w-full mx-auto" style="--width: 890px;">
    {{ page.content }}
  </div>
</div>

{% schema %}
  {
    "name": "Page",
    "settings": [
      {
        "type": "text",
        "id": "additional_text",
        "label": "Additional Text"
      }
    ]
  }
{% endschema %}
