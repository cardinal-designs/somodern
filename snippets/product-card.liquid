{% comment %}
    Renders a product card

    Accepts:
    - prod: {Object} Product Liquid object
    - prioritize_loading: {Boolean} If 'true', the `loading="lazy"` attribute won't be added to the image (optional)

    Usage:
    {% render 'product-card', prod: product %}
{% endcomment %}

{% liquid
  assign image = prod.featured_image

  if prod.selected_or_first_available_variant.image != blank
    assign image = prod.selected_or_first_available_variant.image
  endif

  assign prioritize_loading = prioritize_loading | default: false
%}

<product-card class="group/card block relative">
  <div class="group/image relative">
    <a href="{{ prod.url }}" class="block">
      {% render 'image'
        image: image,
        classes: 'product-card-image w-full aspect-product object-cover',
        sizes: '800px',
        include_placeholder: true,
        placeholder_name: 'product-1',
        fallback_alt: prod.title,
        src_set_type: 'thumbnail',
        prioritize_loading: prioritize_loading
      %}

      {% if prod.images[1] != blank %}
        <div class="inset opacity-0 transition-opacity group-hover/image:opacity-100">
          {% render 'image'
            image: prod.images[1],
            classes: 'product-card-hover size-full inset object-cover hidden md:block',
            sizes: '800px',
            fallback_alt: prod.title,
            src_set_type: 'thumbnail'
          %}
        </div>
      {% endif %}
    </a>

    {% render 'product-badges' prod: prod, classes: 'absolute top-10 left-0' %}

    {% if settings.enable_quickview %}
      <div class="p-13 absolute left-0 right-0 bottom-0 hidden md:block">
        <button
          class="group/quickview w-full button button--white bg-[#E1D5C7] opacity-0 translate-y-5 transition-all relative group-hover/image:opacity-100 group-hover/image:translate-y-0"
          data-quick-view
          data-href="{{ prod.url }}"
          data-id="{{ prod.selected_or_first_available_variant.id }}"
        >
          <span class="transition-opacity group-[.loading]/quickview:opacity-0">+ Quick View</span>
          <span class="inset flex items-center justify-center transition-opacity opacity-0 group-[.loading]/quickview:opacity-100">{% render 'loading-spinner' %}</span>
        </button>
      </div>
    {% endif %}

    <div class="p-15 absolute left-auto right-0 top-0">
    <!-- Swym Wishlist Plus EPI Button with default first variant -->   
      <button aria-label="Add to Wishlist" data-with-epi="true" class="swym-button swym-add-to-wishlist-view-product product_{{prod.id}}" data-swaction="addToWishlist" data-product-id="{{prod.id | json}}" data-variant-id="{{prod.variants[0].id}}" 
      data-product-url="{{ shop.url }}{{ prod.url }}"> 
        <svg xmlns="http://www.w3.org/2000/svg" width="19" height="16" viewBox="0 0 19 16" fill="none">
          <path d="M13.6836 0.505859C14.8998 0.442806 15.9126 0.921544 16.6074 1.74512C17.9567 3.3446 18.1849 6.39599 15.9023 9.46582L15.6738 9.7627C13.9681 11.9037 11.4113 13.871 9.06152 15.4941C6.71112 13.8699 4.15679 11.905 2.4502 9.7627C-0.0748214 6.59426 0.122995 3.39527 1.51562 1.74414C2.21034 0.920664 3.22338 0.442782 4.43945 0.505859C5.66479 0.56942 7.14336 1.18681 8.7207 2.65527L9.06152 2.97266L9.40234 2.65527C10.9796 1.18702 12.4582 0.569436 13.6836 0.505859Z" stroke="#472715"/>
        </svg>
        <svg width="19" height="16" viewBox="0 0 19 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g clip-path="url(#clip0_1621_7)">
          <path d="M13.6839 0.5058C14.9001 0.442747 15.9129 0.921485 16.6077 1.74506C17.957 3.34454 18.1852 6.39593 15.9026 9.46576L15.6741 9.76264C13.9684 11.9036 11.4116 13.8709 9.06186 15.494C6.71146 13.8698 4.15713 11.9049 2.45054 9.76264C-0.0744842 6.5942 0.123332 3.39521 1.51596 1.74408C2.21068 0.920605 3.22372 0.442723 4.43979 0.5058C5.66513 0.569361 7.1437 1.18675 8.72104 2.65521L9.06186 2.9726L9.40268 2.65521C10.9799 1.18696 12.4585 0.569377 13.6839 0.5058Z" fill="#472715" stroke="#472715"/>
          </g>
          <defs>
          <clipPath id="clip0_1621_7">
          <rect width="19" height="16" fill="white"/>
          </clipPath>
          </defs>
        </svg>


      </button>   
     <!-- Swym Wishlist Plus EPI Button-->
    </div>

  </div>

  <div class="mt-10">
    <a href="{{ prod.url }}" class="text-body-1 font-serif">{{ prod.title }}</a>

    {% unless prod.has_only_default_variant %}
      {% for option in prod.options_with_values %}
        {% if option.name == 'Color' %}
          <div class="mt-10 pb-5 gap-10 flex">
            {% for value in option.values %}
              {% liquid
                assign is_active = false

                if option.selected_value == value
                  assign is_active = true
                endif

                for current_variant in prod.variants
                  if current_variant.title contains value
                    assign variant = current_variant
                    break
                  endif
                endfor
              %}

              <button
                class="color-button group/color w-13 h-13 block relative cursor-pointer bg-center{% if is_active %} active{% endif %}"
                data-swatch="{{ value }}"
                data-value="{{ value }}"
                data-position="{{ option.position }}"
                data-id="{{ variant.id }}"
                {% if variant.image %}data-image="{{ variant.image | img_url: '800x' }}"{% endif %}
              >
                <div class="visually-hidden">{{ value }}</div>
                <div class="absolute right-0 -bottom-[4px] left-0 border-b-1 border-transparent transition-colors group-[.active]/color:border-black"></div>
              </button>
            {% endfor %} 
          </div>
        {% endif %}
      {% endfor %}
    {% endunless %}

    {% render 'price' product: prod, classes: 'mt-5 text-body-3' %}
  </div>
</product-card>