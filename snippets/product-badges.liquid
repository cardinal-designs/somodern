{% comment %}
    Renders product badges

    Accepts:
    - prod: {Product}
    - classes: {String}

    Usage:
    {% render 'product-badges', prod: product, show_sale_badge: true %}
{% endcomment %}

{% liquid 
  assign badges = ''
  assign product_tags = prod.tags
  assign badge_tags_1 = settings.badge_tags_1 | split: ', '
  assign badge_tags_2 = settings.badge_tags_2 | split: ', '
  assign badge_tags_3 = settings.badge_tags_3 | split: ', '
  assign badge_tags_4 = settings.badge_tags_4 | split: ', '
  assign badge_tags = badge_tags_1 | concat: badge_tags_2 | concat: badge_tags_3 | concat: badge_tags_4
%}

{% assign badge_count = 0 %}
{% for badge_tag in badge_tags %}
  {% assign current_idx = forloop.index %}
  {% for product_tag in product_tags %}
    {% liquid
      assign product_tag_downcase = product_tag | downcase
      assign badge_tag_downcase = badge_tag | downcase

      assign bg_str = 'badge_tags_idx_color' | replace: 'idx', current_idx
      assign text_str = 'badge_tags_idx_text_color' | replace: 'idx', current_idx
      
      assign bg_color = settings[bg_str]
      assign text_color = settings[text_str]
    %}

    {% if product_tag_downcase == badge_tag_downcase and badge_count < 2 %}
      {% capture badges %}
        <div class="px-[8px] py-[6px] inline-block text-tag font-serif italic bg-mint" style="background-color: {{ bg_color }}; color: {{ text_color }}">{{ badge_tag }}</div>
      {% endcapture %}
      {% assign badge_count = badge_count | plus: 1 %}
    {% endif %}
  {% endfor %}
{% endfor %}

{% if prod.compare_at_price > prod.price %}
  {% capture badges %}
    <div class="px-[8px] py-[6px] inline-block text-tag font-serif italic bg-mint">Sale</div>
  {% endcapture %}
{% endif %}

{% unless prod.available %}
  {% capture badges %}
    <div class="px-[8px] py-[6px] inline-block text-tag font-serif italic bg-mint text-black/50">Out of Stock</div>
  {% endcapture %}
{% endunless %}

{% if badges != blank %}
  <div class="{{ classes }}">
    {{ badges }}
  </div>
{% endif %}
