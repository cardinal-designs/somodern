{% comment %}
  Renders an image, with an optional placeholder.

  Accepts:
    - image: {Object} The image to be rendered.
    - One of the following:
      - sizes: {String} A list of responsive image sizes (for the 'sizes' attributes).
      - sizes_px: {Number} A width (in pixels) for the image.
    - classes: {String} A custom class to be applied to the image wrapper.
    - prioritize_loading: {Boolean} If 'true', the `loading="lazy"` attribute won't be added to the image.
    - include_placeholder: {Boolean} Whether a placeholder should be rendered if no image is provided.
    - placeholder_name: {String} The name of the Shopify placeholder SVG to used.
    - fallback_alt: {String} Alt text to use if the image doesn't have any.
    - no_crop: {Boolean} If 'true', the image will be loaded in full, and then cropped in CSS (rather than
      letting Shopify serve a cropped image).
    - src_set_type: {String} A string noting the kind of environment the image is being rendered in to help
      with more performant srcset generation. If this parameter isn't specified, a comprehensive srcset range
      will be used. Can be:
      - 'grid'
      - 'full-width'
      - 'thumbnail'
  
  Usage:
    {% render 'image'
      image: section.settings.image,
      classes: 'w-full',
      sizes: '100vw',
      include_placeholder: true,
      placeholder_name: 'lifestyle-2',
      src_set_type: 'full-width'
    %}
{% endcomment %}

{% liquid
  if image != image.preview_image and image.preview_image
    assign image = image.preview_image
  endif

  if sizes_px
    assign sizes = sizes_px | append: 'px'
  endif
%}

{% if image != blank %}

  {% liquid
    if fallback_width == blank
      assign fallback_width = 320
    endif

    if lazy
      assign src_attr = "data-src"
      assign src_set_attr = "data-srcset"
    else
      assign src_attr = "src"
      assign src_set_attr = "srcset"
    endif

    case src_set_type
      when "grid"
        # Assumption: even with a 2-per row grid on large screen, grid item will not be more than 700px @2x wide
        assign src_set_widths_raw = "150,200,240,280,300,360,400,450,500,550,600,650,700,750,800,850,900,950,1000,1100,1200,1300,1400"
      when "full-width"
        # Assumption: even smallest phone will be  350px @ 2x = 700 at least
        assign src_set_widths_raw = "700,750,800,850,900,950,1000,1100,1200,1300,1400,1500,1600,1800,2000,2200,2400,2600,2800,3000,3500,4000,4500,5000,5500,6000"
      when "thumbnail"
        # Assumption: even desktop thumbnails shouldn't be more 300px @2x wide = 600 max
        assign src_set_widths_raw = "150,200,240,280,300,360,400,450,500,550,600"
      else
      assign src_set_widths_raw = "100,150,200,240,280,300,360,400,450,500,550,600,650,700,750,800,850,900,950,1000,1100,1200,1300,1400,1500,1600,1800,2000,2200,2400,2600,2800,3000,3500,4000,4500,5000,5500,6000"
    endcase

    assign src_set_widths = src_set_widths_raw | split: ','
    assign src_set_string = ""
  %}

  {% for width_string in src_set_widths %}
    {% assign width = width_string | plus: 0 %}
  
    {% if image.width < width %}
      {% break %}
    {% endif %}
  
    {% capture src_set_string %}
      {% if src_set_string.size > 0 %}{{ src_set_string }},{{ ' ' }}{% endif %}
      {{ image | image_url: width: width }} {{width}}w
    {% endcapture %}
  {% endfor %}
  
  {%- capture alt -%}
    {%- if alt != blank -%}
      {{- alt -}}
    {%- else -%}
      {%- if image.alt.size > 0 -%}
        {{- image.alt | replace: "-", " " -}}
      {%- else -%}
        {{- fallback_alt | replace: "-", " " -}}
      {%- endif -%}
    {%- endif %}
  {%- endcapture -%}

  <div class="image group/image">
    <img
      alt="{{- alt | escape -}}"
      class="opacity-0 transition-opacity group-[.loaded]/image:opacity-100 {{ classes }}"
      {% if prioritize_loading %}fetchpriority="high"{% else %}loading="lazy"{% endif %}
      width="{{ image.width }}"
      height="{{ image.height }}"
      {% unless tag_name == "source" %}{{ src_attr }}="{{ image | image_url: width: fallback_width }}"{% endunless %}
      {% if media %}media="{{ media }}"{% endif %}
      {{ src_set_attr }}="{{ src_set_string }}"
      sizes="{{ sizes }}"
      onload="this.closest('.image').classList.add('loaded')"
    />
  </div>

  {% if image_zoom %}
    <div class="absolute top-0 left-0 w-100 h-100" data-zoom-area> </div>
    <div class="w-full h-full absolute top-0 left-0 opacity-0 md:hover:opacity-100"  style="background-image: url('{{ image | image_url: width: '1200' }}')" data-zoom-window></div>
  {% endif %}
{% elsif include_placeholder %}
  {% liquid
    assign placeholder_tag = 'image'

    if placeholder_name
      assign placeholder_tag = placeholder_name
    endif
  %}

  <div class="placeholder {{ classes }}">
    {{ placeholder_tag | placeholder_svg_tag: 'placeholder-svg' }}
  </div>
{% endif %}