{% liquid
  assign classes = 'button'
  case block.settings.button_color
    when 'white'
      assign classes = 'button button--white'
    when 'black_outline'
      assign classes = 'button button--outline'
    when 'white_outline'
      assign classes = 'button button--white-outline'
  endcase
%}

<div
  class="{% if block.settings.center_button %} mx-auto{% endif %}"
  style="margin-top: {{ block.settings.margin_top }}px;margin-bottom: {{ block.settings.margin_bottom }}px;"
  data-animate {{ block.shopify_attributes }}
>
  {% if block.settings.button_style == 'button' %}
    <a href="{{ block.settings.button_link }}" class="w-fit {{ classes }}">
      {{ block.settings.text }}
    </a>
  {% else %}
    {% render 'text-link' link: block.settings.button_link, label: block.settings.text %}
  {% endif %}
</div>

{% schema %}
  {
    "name": "Button",
    "tag": null,
    "settings": [
      {
        "type": "text",
        "id": "text",
        "label": "Button Label",
        "default": "Shop Now"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      },
      {
        "type": "select",
        "id": "button_style",
        "options": [
          { "value": "button", "label": "Button" },
          { "value": "text", "label": "Text" }
        ],
        "default": "text",
        "label": "Button Style"
      },
      {
        "type": "select",
        "id": "button_color",
        "options": [
          { "value": "white", "label": "White" },
          { "value": "black", "label": "Black" },
          { "value": "white_outline", "label": "White Outline" },
          { "value": "black_outline", "label": "Black Outline" }
        ],
        "default": "white",
        "label": "Button Color",
        "info": "Only applies to button links."
      },
      {
        "type": "header",
        "content": "Config"
      },
      {
        "type": "checkbox",
        "id": "center_button",
        "label": "Center Button"
      },
      {
        "type": "range",
        "id": "margin_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 0,
        "unit": "px",
        "label": "Margin Top"
      },
      {
        "type": "range",
        "id": "margin_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 0,
        "unit": "px",
        "label": "Margin Bottom"
      }
    ],
    "presets": [
      {
        "name": "Button"
      }
    ]
  }
{% endschema %}