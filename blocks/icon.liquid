<div
  class="relative{% if block.settings.center_icon %} mx-auto{% endif %}"
  style="width: {{ block.settings.icon_width }}px;{% if block.settings.icon ==  blank %}height: {{ block.settings.icon_width }}px;{% endif %}margin-top: {{ block.settings.margin_top }}px;margin-bottom: {{ block.settings.margin_bottom }}px;"
  data-animate {{ block.shopify_attributes }}
>
  {% render 'image'
    image: block.settings.icon,
    classes: 'w-full',
    sizes: '300px',
    include_placeholder: true,
    placeholder_name: 'product-3',
    src_set_type: 'grid'
  %}
</div>

{% schema %}
  {
    "name": "Icon",
    "tag": null,
    "settings": [
      {
        "type": "image_picker",
        "id": "icon",
        "label": "Icon"
      },
      {
        "type": "range",
        "id": "icon_width",
        "min": 20,
        "max": 150,
        "step": 5,
        "unit": "px",
        "label": "Icon Width",
        "default": 60
      },
      {
        "type": "header",
        "content": "Config"
      },
      {
        "type": "range",
        "id": "margin_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 0,
        "unit": "px",
        "label": "Margin Top"
      },
      {
        "type": "range",
        "id": "margin_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 0,
        "unit": "px",
        "label": "Margin Bottom"
      },
      {
        "type": "checkbox",
        "id": "center_icon",
        "label": "Center Icon"
      }
    ],
    "presets": [
      {
        "name": "Icon"
      }
    ]
  }
{% endschema %}